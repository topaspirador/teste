      <img src={authorImage} alt={`Foto de ${authorName}`} itemprop="image" loading="lazy" />
      <div>
        <strong itemprop="name">{authorName}</strong><br />
        <span itemprop="jobTitle">{authorJob}</span>
        <p itemprop="description" style="margin: 0.5rem 0; font-size: 0.9rem;">
          Testou pessoalmente todos os modelos apresentados, em casas com pets e diferentes tipos de piso.
        </p>
        <a href={authorLinkedIn} itemprop="sameAs" aria-label="LinkedIn do autor">LinkedIn</a> |
        <a href={authorLattes} itemprop="sameAs" aria-label="Currículo Lattes">Currículo Lattes</a>
      </div>
    </div>

