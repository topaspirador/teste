  </p>
  <button class="cookie-btn" id="aceitar-cookies">OK</button>
</div>

<script>
  // Verifica se o usuário já aceitou os cookies
  if (!localStorage.getItem('cookies-aceitos')) {
    document.getElementById('cookie-banner').classList.add('mostrar');
  }

  // Ao clicar em OK, salva a preferência e esconde
  document.getElementById('aceitar-cookies').addEventListener('click', function() {
    localStorage.setItem('cookies-aceitos', 'sim');
    document.getElementById('cookie-banner').classList.remove('mostrar');
  });
</script>

