    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Qual aspirador é melhor para quem tem alergia a pelos de pet?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Sempre escolha modelos com filtro HEPA, como o Electrolux STK15 ou o WAP Power Speed, pois eles retêm as partículas microscópicas que causam as alergias."
